{
  "_info": "CinematicAI Studio — WAN 2.1 img2video workflow. Requires ComfyUI-WanVideo extension. Variables: {{VIDEO_MODEL}}, {{FIRST_FRAME}}, {{LAST_FRAME}}, {{MOTION_PROMPT}}, {{DURATION_FRAMES}}, {{FPS}}, {{SEED}}, {{OUTPUT_PREFIX}}",
  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "{{VIDEO_MODEL}}",
      "precision": "fp16",
      "attention_mode": "flash_attention"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{FIRST_FRAME}}"
    }
  },
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{LAST_FRAME}}"
    }
  },
  "4": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    }
  },
  "5": {
    "class_type": "CLIPVisionEncode",
    "inputs": {
      "clip_vision": ["4", 0],
      "image": ["2", 0],
      "crop": "center"
    }
  },
  "6": {
    "class_type": "CLIPVisionEncode",
    "inputs": {
      "clip_vision": ["4", 0],
      "image": ["3", 0],
      "crop": "center"
    }
  },
  "7": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "model": ["1", 0],
      "positive_text": "{{MOTION_PROMPT}}, smooth cinematic motion, high quality",
      "negative_text": "jitter, blur, flicker, shake, distortion, artifacts"
    }
  },
  "8": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "conditioning": ["7", 0],
      "image_embeds_start": ["5", 0],
      "image_embeds_end": ["6", 0],
      "num_frames": {{DURATION_FRAMES}},
      "steps": 20,
      "cfg": 5.0,
      "seed": {{SEED}},
      "scheduler": "DEIS",
      "shift": 8.0
    }
  },
  "9": {
    "class_type": "WanVideoDecoder",
    "inputs": {
      "model": ["1", 0],
      "samples": ["8", 0],
      "enable_vae_tiling": true,
      "tile_size_x": 272,
      "tile_size_y": 160,
      "tile_stride_x": 144,
      "tile_stride_y": 96
    }
  },
  "10": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["9", 0],
      "frame_rate": {{FPS}},
      "loop_count": 0,
      "filename_prefix": "{{OUTPUT_PREFIX}}",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true
    }
  }
}
