{
  "_info": "CinematicAI Studio — txt2img base workflow. Variables: {{MODEL}}, {{POSITIVE_PROMPT}}, {{NEGATIVE_PROMPT}}, {{SEED}}, {{STEPS}}, {{CFG}}, {{WIDTH}}, {{HEIGHT}}, {{SAMPLER}}, {{SCHEDULER}}, {{OUTPUT_PREFIX}}",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{MODEL}}"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{POSITIVE_PROMPT}}",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{NEGATIVE_PROMPT}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": {{WIDTH}},
      "height": {{HEIGHT}},
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": {{SEED}},
      "steps": {{STEPS}},
      "cfg": {{CFG}},
      "sampler_name": "{{SAMPLER}}",
      "scheduler": "{{SCHEDULER}}",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "{{OUTPUT_PREFIX}}"
    }
  }
}
