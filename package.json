{
  "name": "cinematic-ai-studio",
  "version": "1.0.0",
  "description": "Automated cinematic video creation with AI and ComfyUI",
  "author": "CinematicAI Studio",
  "main": "src/ui/main.js",
  "scripts": {
    "predev": "node scripts/ensure-dev-ports.mjs",
    "dev:clean": "node scripts/ensure-dev-ports.mjs",
    "dev": "concurrently -n backend,vite,electron -c blue,green,magenta --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:electron": "npx -y wait-on http://127.0.0.1:5300 -t 180000 -v && electron .",
    "dev:vite": "vite",
    "dev:backend": "python -m uvicorn src.core.main:app --reload --reload-dir src/core --reload-delay 2 --port 8123 --host 127.0.0.1",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ui/renderer --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "clsx": "^2.1.1",
    "electron-log": "^5.2.0",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.7",
    "eslint": "^9.12.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vitest": "^2.1.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.cinematicai.studio",
    "productName": "CinematicAI Studio",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/ui/**/*",
      "dist-renderer/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist/cinematic_backend/",
        "to": "backend/cinematic_backend/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "config/",
        "to": "config/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/user_tools/",
        "to": "scripts/user_tools/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CinematicAI Studio",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "differentialPackage": false,
      "runAfterFinish": true,
      "perMachine": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Video"
    }
  }
}
